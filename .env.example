# 服务端口（默认 8765）
PORT=8765

# 服务主机（默认 127.0.0.1，如需局域网访问设为 0.0.0.0）
HOST=127.0.0.1

# 默认模型供应商（可选：agnes, deepseek, qwen, glm, moonshot, openai, ollama）
# DEFAULT_PROVIDER=deepseek

# 默认 API Key（可选，也可以在页面上填写）
# API_KEY=sk-xxxxxxxxxxxxxxxx

# 知识库目录（可选，默认 data/knowledge_base）
# KB_DIR=data/knowledge_base

# 对话记录目录（可选，默认 data/chats）
# CHAT_DIR=data/chats
